generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model School {
  id           String  @id @default(cuid())
  name         String
  logo         String?
  academicYear String?
  timezone     String  @default("Asia/Jakarta")
  address      String?
  phone        String?
  email        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users               User[]
  students            Student[]
  classes             Class[]
  periods             Period[]
  competencyAreas     CompetencyArea[]
  reportCardTemplates ReportCardTemplate[]
  announcements       Announcement[]
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  password String
  name     String
  role     String
  schoolId String
  phone    String?
  address  String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school            School             @relation(fields: [schoolId], references: [id])
  classTeachers     ClassTeacher[]
  domainAssignments DomainAssignment[]
  parentStudents    ParentStudent[]
  picStudents       Student[]          @relation("StudentPIC")
}

model Class {
  id       String @id @default(cuid())
  name     String
  grade    String
  schoolId String

  createdAt DateTime @default(now())

  school            School             @relation(fields: [schoolId], references: [id])
  students          Student[]
  classTeachers     ClassTeacher[]
  domainAssignments DomainAssignment[]
  attendanceRecords AttendanceRecord[]
}

model ClassTeacher {
  id         String  @id @default(cuid())
  classId    String
  teacherId  String
  isHomeroom Boolean @default(false)

  class   Class @relation(fields: [classId], references: [id])
  teacher User  @relation(fields: [teacherId], references: [id])

  @@unique([classId, teacherId])
}

model Student {
  id             String    @id @default(cuid())
  fullName       String
  nickname       String?
  dateOfBirth    DateTime
  classId        String
  schoolId       String
  picTeacherId   String?
  enrollmentDate DateTime  @default(now())
  photo          String?
  medicalNotes   String?
  gender         String?

  createdAt DateTime @default(now())

  class                  Class                  @relation(fields: [classId], references: [id])
  school                 School                 @relation(fields: [schoolId], references: [id])
  picTeacher             User?                  @relation("StudentPIC", fields: [picTeacherId], references: [id])
  parentStudents         ParentStudent[]
  progressEntries        ProgressEntry[]
  attendanceRecords      AttendanceRecord[]
  studentPeriodSummaries StudentPeriodSummary[]
  reportCards            ReportCard[]
  domainCompletions      DomainCompletion[]
}

model ParentStudent {
  id        String @id @default(cuid())
  parentId  String
  studentId String

  parent  User    @relation(fields: [parentId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@unique([parentId, studentId])
}

model Period {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  closeDate DateTime
  type      String   @default("monthly")
  schoolId  String
  isActive  Boolean  @default(false)

  createdAt DateTime @default(now())

  school                 School                 @relation(fields: [schoolId], references: [id])
  progressEntries        ProgressEntry[]
  attendanceRecords      AttendanceRecord[]
  studentPeriodSummaries StudentPeriodSummary[]
  reportCards            ReportCard[]
  domainAssignments      DomainAssignment[]
  domainCompletions      DomainCompletion[]
}

model CompetencyArea {
  id          String  @id @default(cuid())
  name        String
  code        String?
  description String?
  order       Int     @default(0)
  isActive    Boolean @default(true)
  schoolId    String
  customScale Boolean @default(false)

  school             School              @relation(fields: [schoolId], references: [id])
  skills             Skill[]
  domainAssignments  DomainAssignment[]
  domainCompletions  DomainCompletion[]
}

model Skill {
  id               String  @id @default(cuid())
  name             String
  code             String?
  description      String?
  order            Int     @default(0)
  competencyAreaId String

  competencyArea  CompetencyArea  @relation(fields: [competencyAreaId], references: [id])
  progressEntries ProgressEntry[]
}

model DomainAssignment {
  id               String  @id @default(cuid())
  classId          String
  competencyAreaId String
  teacherId        String
  periodId         String?

  class          Class          @relation(fields: [classId], references: [id])
  competencyArea CompetencyArea @relation(fields: [competencyAreaId], references: [id])
  teacher        User           @relation(fields: [teacherId], references: [id])
  period         Period?        @relation(fields: [periodId], references: [id])

  @@unique([classId, competencyAreaId, periodId])
}

model ProgressEntry {
  id               String  @id @default(cuid())
  studentId        String
  skillId          String
  periodId         String
  score            Float
  mappedCode       String?
  narrativeComment String?
  isDraft          Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id])
  skill   Skill   @relation(fields: [skillId], references: [id])
  period  Period  @relation(fields: [periodId], references: [id])

  @@unique([studentId, skillId, periodId])
}

model StudentPeriodSummary {
  id             String    @id @default(cuid())
  studentId      String
  periodId       String
  overallComment String?
  isPublished    Boolean   @default(false)
  publishedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id])
  period  Period  @relation(fields: [periodId], references: [id])

  @@unique([studentId, periodId])
}

model AttendanceRecord {
  id        String   @id @default(cuid())
  studentId String
  classId   String
  periodId  String
  date      DateTime
  status    String

  student Student @relation(fields: [studentId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])
  period  Period  @relation(fields: [periodId], references: [id])

  @@unique([studentId, date])
}

model ReportCardTemplate {
  id       String  @id @default(cuid())
  name     String
  schoolId String
  config   String
  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  school      School       @relation(fields: [schoolId], references: [id])
  reportCards ReportCard[]
}

model ReportCard {
  id          String    @id @default(cuid())
  studentId   String
  periodId    String
  templateId  String
  content     String
  pdfUrl      String?
  isPublished Boolean   @default(false)
  publishedAt DateTime?

  createdAt DateTime @default(now())

  student  Student            @relation(fields: [studentId], references: [id])
  period   Period             @relation(fields: [periodId], references: [id])
  template ReportCardTemplate @relation(fields: [templateId], references: [id])

  @@unique([studentId, periodId])
}

model Announcement {
  id       String  @id @default(cuid())
  title    String
  content  String
  schoolId String
  authorId String?

  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id])
}

model DomainCompletion {
  id               String   @id @default(cuid())
  studentId        String
  competencyAreaId String
  periodId         String
  completedAt      DateTime @default(now())

  student        Student        @relation(fields: [studentId], references: [id])
  competencyArea CompetencyArea @relation(fields: [competencyAreaId], references: [id])
  period         Period         @relation(fields: [periodId], references: [id])

  @@unique([studentId, competencyAreaId, periodId])
}

model AuditLog {
  id        String  @id @default(cuid())
  userId    String?
  action    String
  resource  String
  details   String?
  ipAddress String?

  createdAt DateTime @default(now())
}
